#!/usr/bin/env bash
# deepvariance-claude-code :: CLI
# Run Claude Code against a self-hosted Qwen (OpenAI-compatible) backend.
#   deepvariance launch claude [claude args...]
#   deepvariance config     # (re)enter API key / email / endpoint
#   deepvariance help | version
set -euo pipefail

VERSION="1.2.1"
HOME_DIR="${DEEPVARIANCE_HOME:-$HOME/.deepvariance}"
DEFAULTS="$HOME_DIR/config.default.json"
CONF="$HOME_DIR/config.json"

die() { echo "deepvariance: $*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

# Resolve proxy.js. Prefer the curl-installer layout ($HOME_DIR/lib), then fall
# back to a location relative to this script (npm/npx global install ships
# bin/ and lib/ side by side, so there is no copy step).
SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "$HOME_DIR/lib/proxy.js" ]; then
  LIB="$HOME_DIR/lib/proxy.js"
elif [ -f "$SELF_DIR/../lib/proxy.js" ]; then
  LIB="$SELF_DIR/../lib/proxy.js"
  [ -f "$DEFAULTS" ] || DEFAULTS="$SELF_DIR/../config.default.json"
else
  LIB="$HOME_DIR/lib/proxy.js"
fi

[ -f "$LIB" ] || die "proxy not found (looked in $HOME_DIR/lib and $SELF_DIR/../lib) — reinstall"
have node || die "node is required (>=18). Install Node then retry."
have curl || die "curl is required. Install curl then retry."
have claude || die "claude not found. Install with: npm install -g @anthropic-ai/claude-code"

# jv KEY FILE  -> print JSON string value at top-level KEY (or empty).
# Note: with `node -e`, the first CLI arg is argv[1] (there is no script path).
jv() { node -e 'try{const c=require(process.argv[1]);const v=c[process.argv[2]];process.stdout.write(v==null?"":String(v))}catch(e){}' "$2" "$1"; }

default_of() { [ -f "$DEFAULTS" ] && jv "$1" "$DEFAULTS" || true; }

# Interactive first-run (or `config`) setup. Writes CONF merged with defaults.
setup_config() {
  local def_base cur_base cur_email cur_key key_hint api_base email key
  def_base="$(default_of apiBase)"
  cur_base="$( [ -f "$CONF" ] && jv apiBase "$CONF" || echo "$def_base" )"
  cur_email="$( [ -f "$CONF" ] && jv email "$CONF" || echo "" )"
  cur_key="$( [ -f "$CONF" ] && jv apiKey "$CONF" || echo "" )"

  echo "── deepvariance setup ─────────────────────────────"
  echo "Configuring Claude Code -> self-hosted model."
  echo

  # Model API base URL is required and must be an http(s) URL. There is no
  # working default (the old bundled tunnel URL rotates and dies), so the user
  # must supply a live endpoint.
  local base_prompt="Model API base URL"
  [ -n "$cur_base" ] && base_prompt="$base_prompt [$cur_base]"
  while :; do
    read -r -p "$base_prompt: " api_base
    api_base="${api_base:-$cur_base}"
    case "$api_base" in
      http://*|https://*) break ;;
      "") echo "  A model API base URL is required (e.g. https://your-host/v1)." ;;
      *)  echo "  Must start with http:// or https:// (got '$api_base')." ;;
    esac
  done

  read -r -p "Your email (sent as X-User-Email for usage logging)${cur_email:+ [$cur_email]}: " email
  email="${email:-$cur_email}"
  [ -n "$email" ] || die "email is required"

  # Key entered hidden; keep existing if blank and one already saved.
  key_hint=""
  [ -n "$cur_key" ] && key_hint=" (leave blank to keep existing)"
  read -r -s -p "API key$key_hint: " key; echo
  [ -z "$key" ] && key="$cur_key"
  [ -n "$key" ] || die "API key is required"

  # Validate the endpoint + key before saving so a dead/typo'd URL is caught
  # now, not mid-session as a 502.
  echo -n "Checking endpoint... "
  local code
  code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 25 "$api_base/models" -H "Authorization: Bearer $key" -H "X-User-Email: $email" 2>/dev/null || true)"; code="${code:-000}"
  if [ "$code" = "200" ]; then
    echo "ok (reachable, key accepted)"
  elif [ "$code" = "401" ] || [ "$code" = "403" ]; then
    die "endpoint rejected the key (HTTP $code). Re-run: deepvariance config"
  elif [ "$code" = "000" ]; then
    echo "UNREACHABLE"
    echo "  Could not reach $api_base (DNS/connection failed)."
    echo "  Saving anyway, but 'deepvariance launch claude' will not work until"
    echo "  the backend is up. Verify later with: deepvariance doctor"
  else
    echo "warning: unexpected response (HTTP $code) — saving anyway"
  fi

  mkdir -p "$HOME_DIR"
  API_BASE="$api_base" EMAIL="$email" KEY="$key" DEFAULTS_FILE="$DEFAULTS" OUT="$CONF" node -e '
    const fs=require("fs");
    let d={}; try{ d=require(process.env.DEFAULTS_FILE); }catch(e){}
    const merged=Object.assign({}, d, {
      apiBase: process.env.API_BASE,
      email:   process.env.EMAIL,
      apiKey:  process.env.KEY,
    });
    fs.writeFileSync(process.env.OUT, JSON.stringify(merged, null, 2)+"\n");
  '
  chmod 600 "$CONF"
  echo "Saved $CONF (chmod 600)."
  echo
}

launch_claude() {
  [ -f "$CONF" ] || setup_config
  # Ensure required fields exist (older/partial config or empty default -> setup).
  if [ -z "$(jv apiBase "$CONF")" ] || [ -z "$(jv apiKey "$CONF")" ] || [ -z "$(jv email "$CONF")" ]; then
    setup_config
  fi

  local api_base key model email ctx port tool_mode max_out
  api_base="$(jv apiBase "$CONF")"; [ -n "$api_base" ] || api_base="$(default_of apiBase)"
  model="$(jv model "$CONF")";     [ -n "$model" ]    || model="$(default_of model)"
  ctx="$(jv modelCtx "$CONF")";    [ -n "$ctx" ]      || ctx="$(default_of modelCtx)"; ctx="${ctx:-32768}"
  port="$(jv port "$CONF")";       [ -n "$port" ]     || port="$(default_of port)"; port="${port:-8787}"
  tool_mode="$(jv toolMode "$CONF")"; [ -n "$tool_mode" ] || tool_mode="$(default_of toolMode)"; tool_mode="${tool_mode:-auto}"
  max_out="$(jv maxOutputTokens "$CONF")"; [ -n "$max_out" ] || max_out="$(default_of maxOutputTokens)"; max_out="${max_out:-8192}"
  key="$(jv apiKey "$CONF")"
  email="$(jv email "$CONF")"

  # Fail fast on obviously-bad config instead of handing garbage to the proxy.
  case "$api_base" in
    http://*|https://*) : ;;
    *) die "apiBase must be an http(s) URL (got '$api_base'). Fix with: deepvariance config" ;;
  esac
  case "$ctx" in ''|*[!0-9]*) die "modelCtx must be an integer (got '$ctx')";; esac
  case "$port" in ''|*[!0-9]*) die "port must be an integer (got '$port')";; esac
  case "$max_out" in ''|*[!0-9]*) die "maxOutputTokens must be an integer (got '$max_out')";; esac

  # Preflight: confirm the model backend is actually reachable before starting a
  # session, so a dead/stale endpoint fails here with guidance instead of
  # 502-ing every request mid-session. Override with DEEPVARIANCE_SKIP_UPSTREAM_CHECK=1.
  if [ "${DEEPVARIANCE_SKIP_UPSTREAM_CHECK:-0}" != "1" ]; then
    local up_code
    up_code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 20 "$api_base/models" -H "Authorization: Bearer $key" ${email:+-H "X-User-Email: $email"} 2>/dev/null || true)"; up_code="${up_code:-000}"
    case "$up_code" in
      200) : ;;
      401|403) die "backend rejected the API key (HTTP $up_code). Re-enter it: deepvariance config" ;;
      000) die "model backend unreachable at $api_base (DNS/connection failed).
  Start your model server (and refresh the URL if it is a *.trycloudflare.com tunnel),
  then: deepvariance config   — or check with: deepvariance doctor
  To start anyway: DEEPVARIANCE_SKIP_UPSTREAM_CHECK=1 deepvariance launch claude" ;;
      *) echo "deepvariance: warning: backend returned HTTP $up_code from $api_base/models — continuing" >&2 ;;
    esac
  fi

  if curl -sS "http://127.0.0.1:$port/health" >/dev/null 2>&1; then
    die "port $port already has a deepvariance proxy. Stop it with: deepvariance stop"
  fi

  # Start the Anthropic/OpenAI compatibility proxy.
  UPSTREAM_BASE="$api_base" UPSTREAM_KEY="$key" UPSTREAM_MODEL="$model" \
    USER_EMAIL="$email" MODEL_CTX="$ctx" PORT="$port" \
    TOOL_MODE="$tool_mode" MAX_OUTPUT_TOKENS="$max_out" \
    PROXY_DEBUG="${PROXY_DEBUG:-0}" \
    node "$LIB" &
  local proxy_pid=$!
  echo "$proxy_pid" > "$HOME_DIR/proxy.pid" 2>/dev/null || true
  trap "kill $proxy_pid 2>/dev/null || true; rm -f '$HOME_DIR/proxy.pid' 2>/dev/null || true" EXIT

  # Wait for health (max ~10s).
  local i healthy=0
  for i in $(seq 1 20); do
    if curl -sS "http://127.0.0.1:$port/health" >/dev/null 2>&1; then
      healthy=1
      break
    fi
    if ! kill -0 "$proxy_pid" 2>/dev/null; then
      wait "$proxy_pid" 2>/dev/null || true
      die "proxy failed to start on port $port"
    fi
    sleep 0.5
  done
  [ "$healthy" = "1" ] || die "proxy did not become healthy on port $port"

  # Point Claude Code at the proxy (now Anthropic-compatible).
  export ANTHROPIC_BASE_URL="http://127.0.0.1:$port"
  export ANTHROPIC_AUTH_TOKEN="deepvariance"
  export ANTHROPIC_API_KEY=""
  export ANTHROPIC_MODEL="$model"
  export ANTHROPIC_SMALL_FAST_MODEL="$model"
  export ANTHROPIC_DEFAULT_OPUS_MODEL="$model"
  export ANTHROPIC_DEFAULT_SONNET_MODEL="$model"
  export ANTHROPIC_DEFAULT_HAIKU_MODEL="$model"
  export CLAUDE_CODE_SUBAGENT_MODEL="$model"
  export CLAUDE_CODE_ATTRIBUTION_HEADER=0

  local add_safe_mode=1 safe_mode="on" arg
  local claude_args=()
  for arg in "$@"; do
    case "$arg" in
      --no-safe-mode)
        add_safe_mode=0
        safe_mode="off"
        ;;
      --safe-mode)
        add_safe_mode=0
        safe_mode="on"
        claude_args+=("$arg")
        ;;
      --bare)
        add_safe_mode=0
        safe_mode="bare"
        claude_args+=("$arg")
        ;;
      *)
        claude_args+=("$arg")
        ;;
    esac
  done
  # ${arr[@]+...} guard: bash 3.2 (macOS default) treats an empty array as
  # unset under `set -u`, so bare "${claude_args[@]}" would abort the script.
  if [ "$add_safe_mode" = "1" ]; then
    claude_args=(--safe-mode ${claude_args[@]+"${claude_args[@]}"})
  fi

  echo "deepvariance: proxy on :$port -> $model  (tools: $tool_mode, safe-mode: $safe_mode, user: $email)"
  claude ${claude_args[@]+"${claude_args[@]}"}
}

# Stop a running proxy: prefer the pidfile, fall back to whatever is serving
# /health on the configured port.
stop_proxy() {
  local port pid stopped=0
  port="$( [ -f "$CONF" ] && jv port "$CONF" || echo "" )"; port="${port:-$(default_of port)}"; port="${port:-8787}"
  if [ -f "$HOME_DIR/proxy.pid" ]; then
    pid="$(cat "$HOME_DIR/proxy.pid" 2>/dev/null || true)"
    if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
      kill "$pid" 2>/dev/null && stopped=1
    fi
    rm -f "$HOME_DIR/proxy.pid" 2>/dev/null || true
  fi
  if [ "$stopped" = "0" ]; then
    if curl -sS "http://127.0.0.1:$port/health" >/dev/null 2>&1; then
      pid="$(lsof -tiTCP:"$port" -sTCP:LISTEN 2>/dev/null | head -1 || true)"
      if [ -n "$pid" ]; then kill "$pid" 2>/dev/null && stopped=1; fi
    fi
  fi
  if [ "$stopped" = "1" ]; then
    echo "deepvariance: stopped proxy on port $port"
  else
    echo "deepvariance: no running proxy found on port $port"
  fi
}

# Preflight checklist for "is this machine ready to run real sessions".
doctor() {
  local fails=0 pass="  \033[1;32mok\033[0m" fail="  \033[1;31mFAIL\033[0m"
  echo "── deepvariance doctor ────────────────────────────"

  local node_major
  if have node && node_major="$(node -p 'process.versions.node.split(".")[0]' 2>/dev/null)" && [ "${node_major:-0}" -ge 18 ]; then
    printf '%b node %s\n' "$pass" "$(node -v)"
  else
    printf '%b node >= 18 required (found %s)\n' "$fail" "$(node -v 2>/dev/null || echo none)"; fails=$((fails+1))
  fi

  if have claude; then printf '%b claude %s\n' "$pass" "$(claude --version 2>/dev/null | head -1)"
  else printf '%b claude not found (npm install -g @anthropic-ai/claude-code)\n' "$fail"; fails=$((fails+1)); fi

  [ -f "$LIB" ] && printf '%b proxy library present\n' "$pass" || { printf '%b proxy library missing at %s\n' "$fail" "$LIB"; fails=$((fails+1)); }

  if [ ! -f "$CONF" ]; then
    printf '%b no config yet — run: deepvariance config\n' "$fail"; fails=$((fails+1))
  elif ! node -e 'require(process.argv[1])' "$CONF" >/dev/null 2>&1; then
    printf '%b config is not valid JSON (%s)\n' "$fail" "$CONF"; fails=$((fails+1))
  else
    printf '%b config valid (%s)\n' "$pass" "$CONF"
    local api_base key email port
    api_base="$(jv apiBase "$CONF")"; key="$(jv apiKey "$CONF")"; email="$(jv email "$CONF")"
    port="$(jv port "$CONF")"; port="${port:-8787}"
    [ -n "$key" ]   && printf '%b api key set\n' "$pass"   || { printf '%b api key missing\n' "$fail"; fails=$((fails+1)); }
    [ -n "$email" ] && printf '%b email set (%s)\n' "$pass" "$email" || { printf '%b email missing\n' "$fail"; fails=$((fails+1)); }
    case "$api_base" in http://*|https://*) printf '%b apiBase looks like a URL\n' "$pass";; *) printf '%b apiBase is not an http(s) URL\n' "$fail"; fails=$((fails+1));; esac

    if [ -n "$api_base" ] && [ -n "$key" ]; then
      local code
      code="$(curl -sS -o /dev/null -w '%{http_code}' --max-time 20 "$api_base/models" -H "Authorization: Bearer $key" ${email:+-H "X-User-Email: $email"} 2>/dev/null || echo 000)"
      if [ "$code" = "200" ]; then printf '%b upstream reachable (%s/models -> 200)\n' "$pass" "$api_base"
      elif [ "$code" = "401" ] || [ "$code" = "403" ]; then printf '%b upstream rejected the key (HTTP %s)\n' "$fail" "$code"; fails=$((fails+1))
      else printf '%b upstream not reachable (HTTP %s)\n' "$fail" "$code"; fails=$((fails+1)); fi
    fi

    if curl -sS "http://127.0.0.1:$port/health" >/dev/null 2>&1; then
      printf '%b note: a proxy is already running on port %s\n' "$pass" "$port"
    else
      printf '%b port %s is free\n' "$pass" "$port"
    fi
  fi

  echo "───────────────────────────────────────────────────"
  if [ "$fails" = "0" ]; then echo "All checks passed."; return 0
  else echo "$fails check(s) failed."; return 1; fi
}

cmd="${1:-help}"
case "$cmd" in
  launch)
    target="${2:-}"
    [ "$target" = "claude" ] || die "only 'launch claude' is supported (got '${target:-}')"
    shift 2 || true
    launch_claude "$@"
    ;;
  config)
    setup_config
    ;;
  doctor)
    doctor
    ;;
  stop)
    stop_proxy
    ;;
  version|-v|--version)
    echo "deepvariance $VERSION"
    ;;
  help|-h|--help|*)
    cat <<EOF
deepvariance $VERSION — Claude Code on a self-hosted model

Usage:
  deepvariance launch claude [args]   Start proxy + launch Claude Code
  deepvariance launch claude --no-safe-mode
                                      Launch with user Claude customizations enabled
  deepvariance config                 (Re)enter API key / email / endpoint
  deepvariance doctor                 Preflight checks (node, claude, config, upstream)
  deepvariance stop                   Stop a running proxy
  deepvariance version
  deepvariance help

By default, 'launch claude' adds Claude Code --safe-mode to disable user hooks,
plugins, MCP servers, custom agents, skills, and other customizations. Pass
--no-safe-mode to opt out for a session.

First run of 'launch claude' prompts for your API key + email and saves them to
$CONF (chmod 600). Nothing is sent anywhere except your configured model endpoint.
EOF
    ;;
esac
